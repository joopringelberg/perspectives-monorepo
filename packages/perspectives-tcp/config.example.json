{
  "$schema": "https://raw.githubusercontent.com/joopringelberg/perspectives-monorepo/main/packages/perspectives-tcp/config.schema.json",

  "cuid": "YOUR_TCP_CUID_HERE",

  "rabbitmq": {
    "url": "amqp://guest:guest@localhost:5672/mycontexts",
    "exchange": "amq.topic",
    "prefetch": 10,
    "reconnectDelayMs": 5000
  },

  "database": {
    "client": "better-sqlite3",
    "connection": {
      "filename": "./tcp-data.db"
    }
  },

  "verifySignatures": false,
  "logLevel": "info",

  "schema": {
    "nameMap": {
      "model://stadskamer.org#cuid-bijeenkomst-external": "model://stadskamer.org#Stadskamer$Bijeenkomst$External",
      "model://stadskamer.org#cuid-aanwezigen":           "model://stadskamer.org#Stadskamer$Bijeenkomst$Aanwezigen",
      "model://stadskamer.org#cuid-deelnemer":            "model://stadskamer.org#Stadskamer$Bijeenkomst$Deelnemer",
      "model://perspectives.domains#cuid-persons":        "model://perspectives.domains#System$SocialEnvironment$Persons",
      "model://perspectives.domains#cuid-pu":             "model://perspectives.domains#System$PerspectivesUsers",
      "model://perspectives.domains#cuid-npu":            "model://perspectives.domains#System$NonPerspectivesUsers",
      "model://stadskamer.org#cuid-datum":                "model://stadskamer.org#Stadskamer$Bijeenkomst$External$Datum",
      "model://stadskamer.org#cuid-aanwezig":             "model://stadskamer.org#Stadskamer$Bijeenkomst$Aanwezigen$Aanwezig",
      "model://perspectives.domains#cuid-firstname":      "model://perspectives.domains#System$Identifiable$FirstName",
      "model://perspectives.domains#cuid-lastname":       "model://perspectives.domains#System$Identifiable$LastName",
      "model://stadskamer.org#cuid-bijeenkomst-ctx":      "model://stadskamer.org#Stadskamer$Bijeenkomst"
    },
    "tables": [
      {
        "name": "context",
        "isUniversalContextTable": true,
        "columns": []
      },
      {
        "name": "Bijeenkomst$External",
        "roleType": "model://stadskamer.org#cuid-bijeenkomst-external",
        "columns": [
          {
            "name": "Datum",
            "type": "datetime",
            "nullable": true,
            "propertyType": "model://stadskamer.org#cuid-datum"
          }
        ]
      },
      {
        "name": "Bijeenkomst$Aanwezigen",
        "roleType": "model://stadskamer.org#cuid-aanwezigen",
        "columns": [
          {
            "name": "Aanwezig",
            "type": "boolean",
            "nullable": true,
            "propertyType": "model://stadskamer.org#cuid-aanwezig"
          },
          {
            "name": "FirstName",
            "type": "text",
            "nullable": true,
            "propertyType": "model://perspectives.domains#cuid-firstname",
            "fillerChain": [
              "model://stadskamer.org#cuid-deelnemer",
              "model://perspectives.domains#cuid-persons",
              "model://perspectives.domains#cuid-pu"
            ]
          },
          {
            "name": "LastName",
            "type": "text",
            "nullable": true,
            "propertyType": "model://perspectives.domains#cuid-lastname",
            "fillerChain": [
              "model://stadskamer.org#cuid-deelnemer",
              "model://perspectives.domains#cuid-persons",
              "model://perspectives.domains#cuid-pu"
            ]
          },
          {
            "name": "FirstName",
            "type": "text",
            "nullable": true,
            "propertyType": "model://perspectives.domains#cuid-firstname",
            "fillerChain": [
              "model://stadskamer.org#cuid-deelnemer",
              "model://perspectives.domains#cuid-persons",
              "model://perspectives.domains#cuid-npu"
            ]
          },
          {
            "name": "LastName",
            "type": "text",
            "nullable": true,
            "propertyType": "model://perspectives.domains#cuid-lastname",
            "fillerChain": [
              "model://stadskamer.org#cuid-deelnemer",
              "model://perspectives.domains#cuid-persons",
              "model://perspectives.domains#cuid-npu"
            ]
          }
        ]
      }
    ]
  }
}
