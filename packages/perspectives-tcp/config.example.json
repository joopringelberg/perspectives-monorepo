{
  "$schema": "https://raw.githubusercontent.com/joopringelberg/perspectives-monorepo/main/packages/perspectives-tcp/config.schema.json",

  "cuid": "YOUR_TCP_CUID_HERE",

  "rabbitmq": {
    "url": "amqp://guest:guest@localhost:5672/mycontexts",
    "exchange": "amq.topic",
    "prefetch": 10,
    "reconnectDelayMs": 5000
  },

  "database": {
    "client": "better-sqlite3",
    "connection": {
      "filename": "./tcp-data.db"
    }
  },

  "verifySignatures": false,
  "logLevel": "info",

  "schema": {
    "tables": [
      {
        "name": "context",
        "isUniversalContextTable": true,
        "columns": []
      },
      {
        "name": "stadskamer_orgs",
        "roleType": "model://stadskamer.org#Stadskamer$Stadskamer$External",
        "columns": [
          { "name": "naam", "type": "text", "propertyType": "model://stadskamer.org#Stadskamer$Stadskamer$Naam" }
        ]
      },
      {
        "name": "lokaties",
        "roleType": "model://stadskamer.org#Stadskamer$Stadskamer$Lokatie",
        "columns": [
          { "name": "naam", "type": "text", "propertyType": "model://stadskamer.org#Stadskamer$Lokatie$Naam" },
          { "name": "adres", "type": "text", "propertyType": "model://stadskamer.org#Stadskamer$Lokatie$Adres" }
        ]
      },
      {
        "name": "activiteitencentra",
        "roleType": "model://stadskamer.org#Stadskamer$Lokatie$ActiviteitenCentrum",
        "columns": [
          { "name": "naam", "type": "text", "propertyType": "model://stadskamer.org#Stadskamer$ActiviteitenCentrum$Naam" }
        ]
      },
      {
        "name": "activiteiten",
        "roleType": "model://stadskamer.org#Stadskamer$ActiviteitenCentrum$Activiteit",
        "columns": [
          { "name": "naam", "type": "text", "propertyType": "model://stadskamer.org#Stadskamer$Activiteit$Naam" },
          { "name": "categorie", "type": "text", "propertyType": "model://stadskamer.org#Stadskamer$Activiteit$Categorie" }
        ]
      },
      {
        "name": "bijeenkomsten",
        "roleType": "model://stadskamer.org#Stadskamer$Activiteit$Bijeenkomst",
        "columns": [
          { "name": "datum", "type": "datetime", "propertyType": "model://stadskamer.org#Stadskamer$Bijeenkomst$Datum" },
          { "name": "locatie_naam", "type": "text", "propertyType": "model://stadskamer.org#Stadskamer$Bijeenkomst$LocatieNaam" }
        ]
      },
      {
        "name": "deelnemers",
        "roleType": "model://stadskamer.org#Stadskamer$Bijeenkomst$Deelnemer",
        "columns": [
          { "name": "naam", "type": "text", "propertyType": "model://stadskamer.org#Stadskamer$Deelnemer$Naam" },
          { "name": "aankomst", "type": "datetime", "propertyType": "model://stadskamer.org#Stadskamer$Deelnemer$Aankomst" },
          { "name": "vertrek", "type": "datetime", "propertyType": "model://stadskamer.org#Stadskamer$Deelnemer$Vertrek" }
        ]
      }
    ]
  }
}
