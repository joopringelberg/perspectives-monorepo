      "runtimeArgs": [
        "-e",
        "require('./output/Test.Main/index.js').main()"
      ],
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/output/*.map",
        "!**/node_modules/**"
      ],
      "env": {
        "NODE_EXTRA_CA_CERTS": "/Users/joopringelberg/Library/Application Support/mkcert/rootCA.pem",
        "NODE_TLS_REJECT_UNAUTHORIZED": "0"
